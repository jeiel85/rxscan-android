{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/rxscan/dataset-manifest.schema.json",
  "title": "RxScan Public Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "artifactVersion",
    "schemaVersion",
    "createdAtUtc",
    "minAppVersion",
    "maxAppVersion",
    "freshness",
    "artifact",
    "sourceSnapshots",
    "revokedVersions",
    "emergencyMessageId",
    "signingKeyId"
  ],
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "const": 1
    },
    "artifactVersion": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]+$"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "createdAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "minAppVersion": {
      "type": "string"
    },
    "maxAppVersion": {
      "type": [
        "string",
        "null"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "CURRENT",
        "WARNING",
        "STALE"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "compressedSha256",
        "uncompressedSha256",
        "compressedBytes",
        "uncompressedBytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "compressedSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "uncompressedSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "compressedBytes": {
          "type": "integer",
          "minimum": 1
        },
        "uncompressedBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "sourceSnapshots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceId",
          "snapshotId",
          "fetchedAtUtc",
          "endpoint",
          "rawSha256",
          "recordCount",
          "builderVersion"
        ],
        "properties": {
          "sourceId": {
            "type": "string"
          },
          "snapshotId": {
            "type": "string"
          },
          "fetchedAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "endpoint": {
            "type": "string",
            "format": "uri"
          },
          "sourceUpdatedAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "rawSha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "recordCount": {
            "type": "integer",
            "minimum": 0
          },
          "builderVersion": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "revokedVersions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "emergencyMessageId": {
      "type": [
        "string",
        "null"
      ]
    },
    "signingKeyId": {
      "type": "string",
      "minLength": 1
    }
  }
}
